; Engine configuration file.
; Godot 4.3+ RPG Framework

[application]
config/name="Godot RPG Framework"
config/description="Full-featured RPG framework with ECS combat, dialogue, inventory, quests, and procedural dungeons"
run/main_scene="res://scenes/MainMenu.tscn"
config/version="1.0.0"
config/icon="res://assets/icon.png"

[rendering]
renderer/rendering_method="forward_plus"
quality/intended_usage/framebuffer_allocation=2

[physics]
common/enable_pause_aware_picking=true
2d/default_gravity=980.0

[input]
ui_accept={
"deadzone": 0.5,
